<!-- OVERLAY PARA MÓVIL -->
<div class="sidebar-overlay" [class.active]="sidebarOpen" (click)="toggleSidebar()"></div>

<!-- CONTENEDOR PRINCIPAL -->
<div class="perfil-container">
  
  <!-- SIDEBAR IZQUIERDO -->
  <aside class="sidebar-perfil" [class.active]="sidebarOpen">
    <!-- Header del Sidebar -->
    <div class="sidebar-header">
      <div class="logo-section">
        <img src="assets/img/logo.png" alt="HelpYourPet" class="logo">
        <h3>HelpYourPet</h3>
      </div>
      
      <!-- Foto y datos del usuario -->
      <div class="user-profile">
        <div class="user-avatar">
          <img [src]="usuarioLogueado?.imagen || 'https://ui-avatars.com/api/?name=' + (usuarioLogueado?.nombres || 'Usuario') + '&background=4ade80&color=fff'" 
               alt="Foto de perfil" 
               class="avatar-img">
        </div>
        <h4 class="user-name">{{ usuarioLogueado?.nombres }} {{ usuarioLogueado?.apellidos }}</h4>
        <p class="user-role">Dueño de mascotas</p>
      </div>
    </div>

    <!-- Navegación del Sidebar -->
    <nav class="sidebar-nav">
      <a class="nav-item" 
         [class.active]="activeSection === 'dashboard'" 
         (click)="showSection('dashboard')">
        <i class="fas fa-home"></i>
        <span>Inicio</span>
      </a>
      
      <a class="nav-item" 
         [class.active]="activeSection === 'mascotas'" 
         (click)="showSection('mascotas')">
        <i class="fas fa-paw"></i>
        <span>Mis Mascotas</span>
      </a>
      
      <a class="nav-item" 
         [class.active]="activeSection === 'compras'" 
         (click)="showSection('compras')">
        <i class="fas fa-shopping-cart"></i>
        <span>Mis Compras</span>
      </a>
      
      <a class="nav-item" 
         [class.active]="activeSection === 'adopciones'" 
         (click)="showSection('adopciones')">
        <i class="fas fa-heart"></i>
        <span>Mis Adopciones</span>
      </a>
      
      <a class="nav-item" 
         [class.active]="activeSection === 'configuracion'" 
         (click)="showSection('configuracion')">
        <i class="fas fa-cog"></i>
        <span>Configuración</span>
      </a>
      
      <div class="nav-divider"></div>
      
      <a class="nav-item logout" (click)="logout()">
        <i class="fas fa-sign-out-alt"></i>
        <span>Cerrar Sesión</span>
      </a>
    </nav>
  </aside>

  <!-- CONTENIDO PRINCIPAL -->
  <main class="main-content-perfil">
    
    <!-- Botón menú hamburguesa (solo móvil) -->
    <button class="menu-toggle-btn" (click)="toggleSidebar()">
      <i class="fas fa-bars"></i>
    </button>

    <!-- SECCIÓN: INICIO / DASHBOARD -->
    <section class="content-section" [style.display]="activeSection === 'dashboard' ? 'block' : 'none'">
      <div class="section-header">
        <h2><i class="fas fa-home me-2"></i>Dashboard</h2>
      </div>
      
      <div class="dashboard-grid">
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-paw"></i>
          </div>
          <div class="stat-info">
            <h3>{{ mascotas.length }}</h3>
            <p>Mascotas Registradas</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-shopping-bag"></i>
          </div>
          <div class="stat-info">
            <h3>{{ compras.length }}</h3>
            <p>Compras Realizadas</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-heart"></i>
          </div>
          <div class="stat-info">
            <h3>{{ adopciones.length }}</h3>
            <p>Adopciones</p>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon">
            <i class="fas fa-calendar-check"></i>
          </div>
          <div class="stat-info">
            <h3>{{ citas.length }}</h3>
            <p>Citas Agendadas</p>
          </div>
        </div>
      </div>

      <div class="welcome-card">
        <h3>¡Bienvenido, {{ usuarioLogueado?.nombres }}! 👋</h3>
        <p>Aquí puedes gestionar toda la información de tus mascotas, ver tus compras y mucho más.</p>
      </div>
    </section>

    <!-- SECCIÓN: MIS MASCOTAS -->
    <section class="content-section" [style.display]="activeSection === 'mascotas' ? 'block' : 'none'">
      <div class="section-header">
        <h2><i class="fas fa-paw me-2"></i>Mis Mascotas</h2>
        <button class="btn btn-primary" (click)="agregarMascota()">
          <i class="fas fa-plus me-2"></i>Agregar Mascota
        </button>
      </div>

      <div class="pets-grid" *ngIf="mascotas.length > 0; else noMascotas">
        <div class="pet-card" *ngFor="let mascota of mascotas">
          <div class="pet-image-container">
            <img [src]="mascota.foto || 'assets/img/pet-placeholder.png'" 
                 alt="{{ mascota.nombre }}" 
                 class="pet-image"
                 (error)="onImageError($event)">
            <div class="pet-image-placeholder" style="display: none;">
              <i class="fas fa-paw"></i>
            </div>
          </div>
          <div class="pet-info">
            <h4 class="pet-name">{{ mascota.nombre }}</h4>
            <div class="pet-details">
              <span><i class="fas fa-dog"></i> {{ mascota.especie }}</span>
              <span><i class="fas fa-birthday-cake"></i> {{ mascota.edad }} años</span>
              <span><i class="fas fa-venus-mars"></i> {{ mascota.genero }}</span>
            </div>
            <div class="pet-actions">
              <button class="btn btn-sm btn-info" (click)="verMascota(mascota.id)">
                <i class="fas fa-eye"></i>
              </button>
              <button class="btn btn-sm btn-warning" (click)="editarMascota(mascota.id)">
                <i class="fas fa-edit"></i>
              </button>
              <button class="btn btn-sm btn-danger" (click)="eliminarMascota(mascota.id)">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
        </div>
      </div>

      <ng-template #noMascotas>
        <div class="empty-state">
          <i class="fas fa-paw"></i>
          <h3>No tienes mascotas registradas</h3>
          <p>Agrega tu primera mascota para comenzar</p>
        </div>
      </ng-template>
    </section>

    <!-- SECCIÓN: MIS COMPRAS -->
    <section class="content-section" [style.display]="activeSection === 'compras' ? 'block' : 'none'">
      <div class="section-header">
        <h2><i class="fas fa-shopping-cart me-2"></i>Mis Compras</h2>
        <button class="btn btn-primary" (click)="irATienda()">
          <i class="fas fa-store me-2"></i>Ir a la Tienda
        </button>
      </div>

      <div class="table-container" *ngIf="compras.length > 0; else noCompras">
        <table class="data-table">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Productos</th>
              <th>Total</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <tr *ngFor="let compra of compras">
              <td>{{ compra.fecha | date:'dd/MM/yyyy' }}</td>
              <td>{{ compra.productos }}</td>
              <td class="price">{{ compra.total | currency:'COP':'symbol-narrow':'1.0-0' }}</td>
              <td>
                <span class="badge" [ngClass]="'badge-' + compra.estado">
                  {{ compra.estado }}
                </span>
              </td>
              <td>
                <button class="btn btn-sm btn-info" (click)="verCompra(compra.id)">
                  <i class="fas fa-eye"></i> Ver
                </button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <ng-template #noCompras>
        <div class="empty-state">
          <i class="fas fa-shopping-bag"></i>
          <h3>No tienes compras registradas</h3>
          <p>Visita nuestra tienda para adquirir productos para tus mascotas</p>
        </div>
      </ng-template>
    </section>

    <!-- SECCIÓN: MIS ADOPCIONES -->
    <section class="content-section" [style.display]="activeSection === 'adopciones' ? 'block' : 'none'">
      <div class="section-header">
        <h2><i class="fas fa-heart me-2"></i>Mis Adopciones</h2>
        <button class="btn btn-primary" (click)="irAAdopciones()">
          <i class="fas fa-heart me-2"></i>Ver Adopciones
        </button>
      </div>

      <div class="adopciones-grid" *ngIf="adopciones.length > 0; else noAdopciones">
        <div class="adopcion-card" *ngFor="let adopcion of adopciones">
          <div class="adopcion-image">
            <img [src]="adopcion.foto || 'assets/img/pet-placeholder.png'" alt="{{ adopcion.nombre }}">
          </div>
          <div class="adopcion-info">
            <h4>{{ adopcion.nombre }}</h4>
            <p><i class="fas fa-calendar"></i> {{ adopcion.fecha | date:'dd/MM/yyyy' }}</p>
            <span class="badge" [ngClass]="'badge-' + adopcion.estado">{{ adopcion.estado }}</span>
          </div>
        </div>
      </div>

      <ng-template #noAdopciones>
        <div class="empty-state">
          <i class="fas fa-heart"></i>
          <h3>No tienes adopciones registradas</h3>
          <p>Explora las mascotas disponibles para adopción</p>
        </div>
      </ng-template>
    </section>

    <!-- SECCIÓN: CONFIGURACIÓN -->
    <section class="content-section" [style.display]="activeSection === 'configuracion' ? 'block' : 'none'">
      <div class="section-header">
        <h2><i class="fas fa-cog me-2"></i>Configuración</h2>
      </div>

      <!-- DOS COLUMNAS: Información Personal + Cambiar Contraseña -->
      <div class="config-grid">

        <!-- Columna 1: Información Personal -->
        <div class="config-card">
          <div class="config-card-header">
            <i class="fas fa-user"></i>
            <h3>Información Personal</h3>
          </div>
          <form class="config-form">
            <div class="form-group">
              <label>Nombres</label>
              <input type="text" class="form-control" [(ngModel)]="usuarioLogueado.nombres" name="nombres">
            </div>
            <div class="form-group">
              <label>Apellidos</label>
              <input type="text" class="form-control" [(ngModel)]="usuarioLogueado.apellidos" name="apellidos">
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" class="form-control" [(ngModel)]="usuarioLogueado.email" name="email">
            </div>
            <div class="form-group">
              <label>Teléfono</label>
              <input type="tel" class="form-control" [(ngModel)]="usuarioLogueado.telefono" name="telefono">
            </div>
            <div class="form-actions">
              <button type="button" class="btn btn-primary" (click)="guardarPerfil()">
                <i class="fas fa-save me-2"></i>Guardar Cambios
              </button>
            </div>
          </form>
        </div>

        <!-- Columna 2: Cambiar Contraseña -->
        <div class="config-card">
          <div class="config-card-header">
            <i class="fas fa-lock"></i>
            <h3>Cambiar Contraseña</h3>
          </div>
          <form class="config-form">
            <div class="form-group">
              <label>Contraseña Actual</label>
              <input type="password" class="form-control" placeholder="••••••••">
            </div>
            <div class="form-group">
              <label>Nueva Contraseña</label>
              <input type="password" class="form-control" placeholder="••••••••">
            </div>
            <div class="form-group">
              <label>Confirmar Nueva Contraseña</label>
              <input type="password" class="form-control" placeholder="••••••••">
            </div>
            <div class="form-actions">
              <button type="button" class="btn btn-warning">
                <i class="fas fa-key me-2"></i>Cambiar Contraseña
              </button>
            </div>
          </form>
        </div>

      </div>

      <!-- Fila completa: Zona de Peligro -->
      <div class="config-card danger-zone">
        <div class="config-card-header danger-header">
          <i class="fas fa-exclamation-triangle"></i>
          <h3>Zona de Peligro</h3>
        </div>
        <p>Una vez que elimines tu cuenta, no hay vuelta atrás. Todos tus datos, mascotas y compras serán eliminados permanentemente.</p>
        <button class="btn btn-danger">
          <i class="fas fa-trash me-2"></i>Eliminar Cuenta
        </button>
      </div>
    </section>

  </main>
</div>
