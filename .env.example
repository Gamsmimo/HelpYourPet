# Copia este archivo a .env.development y ajusta los valores
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=helppet
DB_PASSWORD=helppet123
DB_DATABASE=help_your_pet

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# CORS
FRONTEND_URL=http://localhost:4200

# Stripe (modo prueba)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Logging
LOG_LEVEL=debug
